light_end":10},{"text":"    }","highlight_start":1,"highlight_end":6},{"text":"    ","highlight_start":1,"highlight_end":5},{"text":"    pub fn initialize(&mut self) -> Result<(i32, i32), EglError> {","highlight_start":1,"highlight_end":67},{"text":"        unsafe {","highlight_start":1,"highlight_end":17},{"text":"            let mut major: EGLint = 0;","highlight_start":1,"highlight_end":39},{"text":"            let mut minor: EGLint = 0;","highlight_start":1,"highlight_end":39},{"text":"            let r = eglInitialize(self.handle, &mut major, &mut minor);","highlight_start":1,"highlight_end":72},{"text":"            if r == EGL_SUCCESS { self.initialized = true; Ok((major as i32, minor as i32)) }","highlight_start":1,"highlight_end":94},{"text":"            else { Err(EglError::from_egl_error(r)) }","highlight_start":1,"highlight_end":54},{"text":"        }","highlight_start":1,"highlight_end":10},{"text":"    }","highlight_start":1,"highlight_end":6},{"text":"    ","highlight_start":1,"highlight_end":5},{"text":"    pub fn choose_config(&self, attribs: &[EGLint]) -> Result<EGLConfig, EglError> {","highlight_start":1,"highlight_end":85},{"text":"        unsafe {","highlight_start":1,"highlight_end":17},{"text":"            let mut cfg: EGLConfig = core::ptr::null_mut();","highlight_start":1,"highlight_end":60},{"text":"            let mut n: EGLint = 0;","highlight_start":1,"highlight_end":35},{"text":"            let r = eglChooseConfig(self.handle, attribs.as_ptr(), &mut cfg, 1, &mut n);","highlight_start":1,"highlight_end":89},{"text":"            if r == EGL_SUCCESS && n > 0 && !cfg.is_null() { Ok(cfg) }","highlight_start":1,"highlight_end":71},{"text":"            else { Err(EglError::from_egl_error(r)) }","highlight_start":1,"highlight_end":54},{"text":"        }","highlight_start":1,"highlight_end":10},{"text":"    }","highlight_start":1,"highlight_end":6},{"text":"    ","highlight_start":1,"highlight_end":5},{"text":"    pub fn create_window_surface(&se