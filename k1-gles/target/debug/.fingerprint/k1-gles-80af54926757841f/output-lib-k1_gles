re = \"mock\"))]","highlight_start":1,"highlight_end":58},{"text":"use mock_impl::*;","highlight_start":1,"highlight_end":18},{"text":"","highlight_start":1,"highlight_end":1},{"text":"// ==================== Error Handling ====================","highlight_start":1,"highlight_end":60},{"text":"","highlight_start":1,"highlight_end":1},{"text":"#[derive(Debug, Clone, PartialEq)]","highlight_start":1,"highlight_end":35},{"text":"pub enum EglError {","highlight_start":1,"highlight_end":20},{"text":"    NotInitialized, BadAccess, BadAlloc, BadAttribute, BadConfig,","highlight_start":1,"highlight_end":66},{"text":"    BadContext, BadCurrentSurface, BadDisplay, BadMatch,","highlight_start":1,"highlight_end":57},{"text":"    BadNativePixmap, BadNativeWindow, BadParameter, BadSurface,","highlight_start":1,"highlight_end":64},{"text":"    Unknown(EGLint), Message(String),","highlight_start":1,"highlight_end":38},{"text":"}","highlight_start":1,"highlight_end":2},{"text":"","highlight_start":1,"highlight_end":1},{"text":"impl EglError {","highlight_start":1,"highlight_end":16},{"text":"    fn from_egl_error(err: EGLint) -> Self {","highlight_start":1,"highlight_end":45},{"text":"        match err {","highlight_start":1,"highlight_end":20},{"text":"            EGL_NOT_INITIALIZED => Self::NotInitialized,","highlight_start":1,"highlight_end":57},{"text":"            EGL_BAD_ACCESS => Self::BadAccess,","highlight_start":1,"highlight_end":47},{"text":"            EGL_BAD_ALLOC => Self::BadAlloc,","highlight_start":1,"highlight_end":45},{"text":"            EGL_BAD_ATTRIBUTE => Self::BadAttribute,","highlight_start":1,"highlight_end":53},{"text":"            EGL_BAD_CONFIG => Self::BadConfig,","highlight_start":1,"highlight_end":47},{"text":"            EGL_BAD_CONTEXT => Self::BadContext,","highlight_start":1,"highlight_end":49},{"text":"            EGL_BAD_CURRENT_SURFACE => Self::BadCurrentSurface,","highlight_start":1,"highlight_end":64},{"text":"            EGL_BAD_DISPLAY => 